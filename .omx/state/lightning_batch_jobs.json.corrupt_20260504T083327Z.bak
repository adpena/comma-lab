score = payload.get('score_recomputed_from_components')\nassert isinstance(score, (int, float)) and math.isfinite(score), score\nexpected_sha = '6174424516a93aa35852cd4dc22b9132516fc38f824b77562b3f91b3f55f58dc'\nexpected_bytes = 283432\nif expected_sha is not None:\n    assert prov.get('archive_sha256') == expected_sha, prov.get('archive_sha256')\nif expected_bytes is not None:\n    assert payload.get('archive_size_bytes') == expected_bytes, payload.get('archive_size_bytes')\nprint('LIGHTNING_EXACT_CUDA_EVAL_JSON_OK')\nprint(json.dumps({'score_recomputed_from_components': score, 'archive_sha256': prov.get('archive_sha256'), 'archive_size_bytes': payload.get('archive_size_bytes'), 'gpu_model': prov.get('gpu_model'), 'gpu_t4_match': prov.get('gpu_t4_match')}, sort_keys=True))\nPY\n.venv/bin/python -u experiments/contest_component_trace.py --submission-dir /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_20260503T0142Z/eval_work --upstream-dir /teamspace/studios/this_studio/pact/upstream --uncompressed-dir /teamspace/studios/this_studio/pact/upstream/videos --video-names-file /teamspace/studios/this_studio/pact/upstream/public_test_video_names.txt --device cuda --contest-auth-eval-json /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_20260503T0142Z/contest_auth_eval.json --output-json /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_20260503T0142Z/component_trace.json --top-k 80 2>&1 | tee /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_20260503T0142Z/component_trace.log\ntest -f /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_20260503T0142Z/component_trace.json\n.venv/bin/python - /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_trained_qbf1_b0512_g7e_2