score_source\": \"contest_auth_eval.json:score_recomputed_from_components\", \"status_source\": \"lightning_sdk_job_attributes\"}' <<'PY'\nimport json, sys, time\npayload = json.loads(sys.argv[2])\npayload['artifact_recorded_at_utc'] = time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())\nopen(sys.argv[1], 'w').write(json.dumps(payload, indent=2, sort_keys=True) + '\\n')\nPY\n.venv/bin/python scripts/scan_lightning_supply_chain.py --json-out /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_pr85_stbm1br_pr92_rmb1_t4_20260504T082220Z/lightning_supply_chain_scan_pre.json --quiet --strict\nLIGHTNING_VENV_LOCK=.omx/state/lightning_exact_eval_venv.lock\nLIGHTNING_VENV_LOCK_ACQUIRED=0\nfor _ in $(seq 1 600); do\n  if mkdir \"$LIGHTNING_VENV_LOCK\" 2>/dev/null; then\n    LIGHTNING_VENV_LOCK_ACQUIRED=1\n    printf \"%s\\n\" \"$$\" > \"$LIGHTNING_VENV_LOCK/pid\"\n    break\n  fi\n  sleep 2\ndone\nif [ \"$LIGHTNING_VENV_LOCK_ACQUIRED\" != \"1\" ]; then\n  echo 'FATAL: timed out waiting for Lightning exact-eval venv lock' >&2\n  exit 43\nfi\ntrap 'rm -rf \"$LIGHTNING_VENV_LOCK\"' EXIT\n.venv/bin/python - /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_pr85_stbm1br_pr92_rmb1_t4_20260504T082220Z/lightning_dali_bootstrap.json /teamspace/studios/this_studio/pact/experiments/results/lightning_batch/exact_eval_pr85_stbm1br_pr92_rmb1_t4_20260504T082220Z/lightning_dali_requirements.txt '{\"common\": [{\"name\": \"absl-py\", \"sha256\": \"eeecf07f0c2a93ace0772c92e596ace6d3d3996c042b2128459aaae2a76de11d\", \"url\": \"https://files.pythonhosted.org/packages/8f/aa/ba0014cc4659328dc818a28827be78e6d97312ab0cb98105a770924dc11e/absl_py-2.3.1-py3-none-any.whl\", \"version\": \"2.3.1\"}, {\"name\": \"astunparse\", \"sha256\": \"c2652417f2c8b5bb325c885ae329bdf3f86424075c4fd1a128674bc6fba4b8e8\", \"url\": \"https://files.pythonhosted.org/packages/2b/03/13dde6512ad7b4557eb792fbcf0c653af6076b81e5941d36ec61f7ce6028/astunparse-1.6.3-py