{
  "version": 2,
  "description": "Review policy — capability-based approval requirements per file pattern",

  "_design_notes": {
    "philosophy": "LLVM/Chromium OWNERS model: capability levels, not org structure",
    "levels": "L1 < L2 < L3 < L4 — each inherits the previous",
    "enforcement": "Pre-commit hook checks policy; blocks or warns based on config"
  },

  "principals": {
    "adpena": {
      "github": "adpena",
      "url": "https://github.com/adpena",
      "level": 4,
      "level_name": "owner",
      "scope": ["*"],
      "human": true
    },
    "council": {
      "_description": "LLM agent review during interactive sessions (manual mark commands)",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    },
    "council_greenup": {
      "_description": "LLM agent review via greenup protocol (batch file-by-file passes)",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    },
    "codex": {
      "_description": "External adversarial review via /codex:adversarial-review (challenges assumptions, finds gaps the inner council missed)",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    },
    "council_5369_review": {
      "github": null,
      "url": null,
      "level": 2,
      "level_name": "reviewer",
      "scope": ["src/tac/*", "experiments/*"],
      "human": false
    },
    "diff_scanner": {
      "github": null,
      "url": null,
      "level": 1,
      "level_name": "contributor",
      "scope": ["*"],
      "human": false
    },
    "yousfi": {
      "_description": "Tripartite pact member — domain expert, contest designer perspective",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    },
    "fridrich": {
      "_description": "Tripartite pact member — steganalysis founder, constrained optimization expert",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    },
    "contrarian": {
      "_description": "Tripartite pact member — rigor enforcer, veto power on unvalidated assumptions",
      "github": null,
      "url": null,
      "level": 3,
      "level_name": "approver",
      "scope": ["*"],
      "human": false
    }
  },

  "levels": {
    "1": {"name": "contributor", "can": ["comment", "flag"]},
    "2": {"name": "reviewer",    "can": ["comment", "flag", "review"]},
    "3": {"name": "approver",    "can": ["comment", "flag", "review", "approve"]},
    "4": {"name": "owner",       "can": ["comment", "flag", "review", "approve", "override"]}
  },

  "rigor": {
    "critical": {
      "description": "Production-critical code — bugs cost GPU hours or corrupt submissions",
      "min_consecutive_clean_passes": 3,
      "min_approver_level": 3,
      "min_distinct_approvers": 2,
      "require_human_approver": false,
      "require_all_issues_resolved": true,
      "stale_resets_passes": true,
      "max_staleness_days": 7
    },
    "standard": {
      "description": "Core library code — foundational but not in the hot path",
      "min_consecutive_clean_passes": 2,
      "min_approver_level": 2,
      "min_distinct_approvers": 1,
      "require_human_approver": false,
      "require_all_issues_resolved": true,
      "stale_resets_passes": true,
      "max_staleness_days": 14
    },
    "normal": {
      "description": "Experiment scripts, utilities, tooling",
      "min_consecutive_clean_passes": 1,
      "min_approver_level": 1,
      "min_distinct_approvers": 1,
      "require_human_approver": false,
      "require_all_issues_resolved": true,
      "stale_resets_passes": false,
      "max_staleness_days": 30
    },
    "relaxed": {
      "description": "Config, data, non-executable files",
      "min_consecutive_clean_passes": 1,
      "min_approver_level": 1,
      "min_distinct_approvers": 1,
      "require_human_approver": false,
      "require_all_issues_resolved": false,
      "stale_resets_passes": false,
      "max_staleness_days": 90
    }
  },

  "_file_policies_note": "ORDER MATTERS: first match wins. fnmatch '*' matches '/', so patterns for subdirectories (e.g. src/tac/lossless/) must appear BEFORE their parent catch-all. Exact-file patterns go first, then subdirectory patterns, then single-level globs.",

  "file_policies": [
    {"pattern": "src/tac/training.py",                    "rigor": "critical", "reason": "Core training loop — bugs cost GPU hours"},
    {"pattern": "src/tac/losses.py",                      "rigor": "critical", "reason": "Loss functions directly determine model quality"},
    {"pattern": "src/tac/renderer.py",                    "rigor": "critical", "reason": "GPU lane renderer — complex architecture"},
    {"pattern": "src/tac/quantization.py",                "rigor": "critical", "reason": "Quantization affects deployed model quality"},
    {"pattern": "src/tac/diffusion_renderer.py",          "rigor": "critical", "reason": "Complex diffusion math — easy to break"},
    {"pattern": "submissions/robust_current/compress.sh",  "rigor": "critical", "reason": "Submission pipeline — must be correct"},
    {"pattern": "submissions/robust_current/inflate*.py",  "rigor": "critical", "reason": "Inflate pipeline — runs on scorer"},
    {"pattern": "src/tac/lossless/*.py",                  "rigor": "standard", "reason": "Lossless codec modules"},
    {"pattern": "src/tac/*.py",                            "rigor": "standard", "reason": "Core tac library modules (NOTE: fnmatch * matches /, so this also catches subdirs — place subdirectory overrides above)"},
    {"pattern": "experiments/train_*.py",                 "rigor": "standard", "reason": "Training scripts — need correctness"},
    {"pattern": "experiments/*.py",                       "rigor": "normal",   "reason": "Experiment scripts"},
    {"pattern": "tools/*.py",                             "rigor": "normal",   "reason": "Developer tooling"},
    {"pattern": "*",                                      "rigor": "relaxed",  "reason": "Default fallback"}
  ],

  "enforcement": {
    "_note": "When warn_only is true, ALL block_on_* settings are advisory only (warnings, not blocking). Set warn_only to false for block_on_* to actually prevent commits.",
    "pre_commit_enabled": true,
    "warn_only": true,
    "block_on_needs_fix": true,
    "block_on_insufficient_passes": true,
    "block_on_insufficient_approver_level": true,
    "block_on_stale_approval": true,
    "override_env_var": "REVIEW_GATE_OVERRIDE",
    "disable_env_var": "REVIEW_GATE_ENABLED"
  }
}
