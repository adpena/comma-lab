# EditorConfig — https://editorconfig.org
# Following comma.ai/openpilot canonical project conventions.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 120

[*.{md,rst,txt}]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 4

[*.{c,cc,cpp,h,hpp,cu,cuh}]
indent_size = 2

[*.rs]
indent_size = 4
