# AV1+ROI multi-stream experimental config
# Based on flat AV1 floor, with static ROI enabled

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=33
SVT_AV1_PARAMS=film-grain=22:keyint=180:scd=0
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0

# ROI settings
ROI_ENABLE=1
ROI_METADATA_ENABLE=0
ROI_X_FRAC=0.15
ROI_Y_FRAC=0.35
ROI_W_FRAC=0.70
ROI_H_FRAC=0.55
ROI_BASE_CRF_DELTA=6
ROI_CRF_DELTA=-2
ROI2_ENABLE=0

# Preprocessing disabled for multi-stream lane
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=hqdn3d=1.5:0:0:0
