# Match PR #24 exactly: CRF 33 + Python bicubic upscale + binomial USM 0.85
# PR #24 scored 2.05 with this config.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=33
SVT_AV1_PARAMS=film-grain=22:keyint=180:scd=0:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=

# Python inflate matching PR #24
PYTHON_INFLATE=1
PYTHON_INFLATE_UPSCALE=bicubic
PYTHON_INFLATE_USM_STRENGTH=0.85
PYTHON_INFLATE_USM_KERNEL=9

INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
