# Experiment H: Consensus params + sharpness=1
# sharpness=1 is confirmed to help by PR #23 (scored 2.08)
# Combined with CRF 33 + scd=0 + hqdn3d (our updated baseline)
# This is the safest "quick win" experiment.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=33
SVT_AV1_PARAMS=film-grain=22:keyint=180:scd=0:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=hqdn3d=1.5:0:0:0
