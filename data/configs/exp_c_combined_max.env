# Experiment C: Combined maximum aggression
# ROI preprocess + VQ mode + QM + film-grain-denoise + block-aligned resolution
# Hypothesis: stacking all winning techniques yields the best possible score.
# Risk: interactions between techniques may not all be additive.

SCALE_W=512
SCALE_H=384
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=33
SVT_AV1_PARAMS=tune=0:enable-variance-boost=1:variance-boost-strength=2:enable-qm=1:qm-min=0:qm-max=15:film-grain=22:film-grain-denoise=1:keyint=180:scd=0:sharpness=2
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.40:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0

# ROI preprocessing enabled
ROI_PREPROCESS_ENABLE=1
ROI_PREPROCESS_BLUR_SIGMA=3.0
ROI_PREPROCESS_FEATHER_RADIUS=48
ROI_PREPROCESS_BLEND=0.65
ROI_PREPROCESS_CORRIDOR_TL=0.18,0.42
ROI_PREPROCESS_CORRIDOR_TR=0.82,0.42
ROI_PREPROCESS_CORRIDOR_BR=1.0,1.0
ROI_PREPROCESS_CORRIDOR_BL=0.0,1.0
PRE_DENOISE=hqdn3d=1.5:0:0:0
