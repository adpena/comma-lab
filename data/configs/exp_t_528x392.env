# Experiment T: 528x392 resolution (public consensus) + sharpness=1
# Most top entries use ~528x392 (45% of 1164x874). We use 524x394.
# The 4px difference may affect CTU alignment.

SCALE_W=528
SCALE_H=392
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=
