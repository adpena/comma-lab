# CRITICAL EXPERIMENT: Python-based inflate with bicubic upscale + binomial USM
# This matches the approach used by PR #24 (2.05) and PR #31 (1.95).
# The key difference from our current pipeline: Python bicubic upscale + binomial
# USM kernel instead of ffmpeg lanczos + Gaussian unsharp.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=

# Python inflate (overrides ffmpeg inflate)
PYTHON_INFLATE=1
PYTHON_INFLATE_UPSCALE=bicubic
PYTHON_INFLATE_USM_STRENGTH=0.40
PYTHON_INFLATE_USM_KERNEL=9

# Not used when PYTHON_INFLATE=1, but kept for compatibility
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
