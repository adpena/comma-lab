+constexpr int CTX_COUNT = 216;
+constexpr int CTX5_COUNT = 7776;
+constexpr int CTX6_COUNT = 46656;
+constexpr int CTX7_COUNT = 279936;
+constexpr int CTX8_COUNT = 1679616;
