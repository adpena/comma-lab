+      // been rejected, so valid predictor classes are unlikely in this branch.
+      for (uint8_t cls = 0; cls < CLASS_SYMS; cls++) {
+        if (cls != up && cls != left && cls != prev) class_freq[ctx][cls] = FALLBACK_OTHER_INIT;
+      }
+    }
