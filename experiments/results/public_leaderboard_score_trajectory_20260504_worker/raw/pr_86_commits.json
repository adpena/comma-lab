[{"sha":"b326decbdc4aefdca363e1c3fa770765a5bae250","node_id":"C_kwDOSTcHo9oAKGIzMjZkZWNiZGM0YWVmZGNhMzYzZTFjM2ZhNzcwNzY1YTViYWUyNTA","commit":{"author":{"name":"jas0xf","email":"jas0xf@gmail.com","date":"2026-05-03T23:07:52Z"},"committer":{"name":"jas0xf","email":"jas0xf@gmail.com","date":"2026-05-03T23:07:52Z"},"message":"submission: jas0xf_adversarial_neural_representation (0.27)\n\nToken-based neural codec with master TokenRendererV62 + slave ShrinkSingleNeRV\n+ HPAC autoregressive entropy model. 207 KB archive decodes back to a 60-second\n1164x874 driving clip in ~22 min on a Tesla T4. Final score: 0.27.\n\nIncludes inflate.py + inflate.sh (decoder), compress.py + compress.sh + training/\n(full training pipeline with off-the-shelf placeholder hyperparameters during\nthe active competition window), the validated archive.zip, the eval report, a\n24-page writeup, and two demo GIFs in assets/.\n\nAdds constriction + pyppmd to pyproject.toml (used by inflate.py for arithmetic\ndecoding of tokens.bin and PPMd decompression of hpac.pt.ppmd respectively).","tree":{"sha":"088a34a8d5d3dcaa76c4d5cce96c396a30513290","url":"https://api.github.com/repos/commaai/comma_video_compression_challenge/git/trees/088a34a8d5d3dcaa76c4d5cce96c396a30513290"},"url":"https://api.github.com/repos/commaai/comma_video_compression_challenge/git/commits/b326decbdc4aefdca363e1c3fa770765a5bae250","comment_count":0,"verification":{"verified":false,"reason":"unsigned","signature":null,"payload":null,"verified_at":null}},"url":"https://api.github.com/repos/commaai/comma_video_compression_challenge/commits/b326decbdc4aefdca363e1c3fa770765a5bae250","html_url":"https://github.com/commaai/comma_video_compression_challenge/commit/b326decbdc4aefdca363e1c3fa770765a5bae250","comments_url":"https://api.github.com/repos/commaai/comma_video_compression_challenge/commits/b326decbdc4aefdca363e1c3fa770765a5bae250/comments","author":null,"committer":null,"parents":[{"sha":"6a1ea25129d75ce30b3fc4e35e30a05f9a93b4ba"