+        arr[~bits] = fp
+        state_dict[special] = torch.from_numpy(arr).float()
+
+    if offset != len(pay):
+        raise ValueError(f"qrow grouped model decode consumed {offset} bytes, payload has {len(pay)}")
+    return state_dict
