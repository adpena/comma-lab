+            t = get_target(total)
+            s = 0
+            while cdf_row[s + 1] <= t:
+                s += 1
+            frame_list[y][x] = inv[s]
+            advance(cdf_row[s], cdf_row[s + 1], total)
+    for y in range(h):
+        frame[y] = frame_list[y]
