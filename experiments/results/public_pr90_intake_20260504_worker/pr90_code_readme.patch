+def _binary_ctx_frame(mask: np.ndarray, fi: int, feat_ids: tuple[int, ...]) -> np.ndarray:
+    frame = mask[fi]
+    h, w = frame.shape
+    out = np.zeros((h, w), dtype=np.int64)
+    for fid in feat_ids:
