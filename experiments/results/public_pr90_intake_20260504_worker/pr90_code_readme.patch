+    for name, arr in bias_bytes.items():
+        state_dict[f"{name}.bias"] = torch.from_numpy(arr).float()
+    for name, arr in dense_float_bytes.items():
+        state_dict[name] = torch.from_numpy(arr).float()
+    for name, arr in dense_int_bytes.items():
