+                m10_ctx = m10_ctx * 5 + fv
+
+            slot = m10_to_slot_dict.get(m10_ctx)
+            if slot is None:
+                cdf_row = m7_cdf_flat_py[m7_ctx]
+            else:
+                cdf_row = fired_cdf_flat_py[slot]
