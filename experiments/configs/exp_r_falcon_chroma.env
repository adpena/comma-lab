# Experiment R: Falcon Perception ML masks + chroma-only degradation
# Uses ML-generated importance masks from Falcon Perception (25% coverage)
# Combined with chroma-only degradation (PoseNet-safe — preserves luminance)
# Plus sharpness=1 (our validated floor winner)
# This is the most innovative approach in our pipeline.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0

# ML mask + chroma-only preprocessing
ROI_PREPROCESS_ENABLE=1
ROI_PREPROCESS_CHROMA_ONLY=1
ROI_PREPROCESS_MASK_FILE=experiments/masks/falcon_keyframes.npy
ROI_PREPROCESS_BLUR_SIGMA=4.0
ROI_PREPROCESS_FEATHER_RADIUS=16
ROI_PREPROCESS_BLEND=0.60
ROI_PREPROCESS_CORRIDOR_TL=0.10,0.30
ROI_PREPROCESS_CORRIDOR_TR=0.90,0.30
ROI_PREPROCESS_CORRIDOR_BR=1.0,1.0
ROI_PREPROCESS_CORRIDOR_BL=0.0,1.0
ROI_PREPROCESS_ADAPTIVE=0
PRE_DENOISE=
