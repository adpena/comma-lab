# Experiment K: GENTLE preprocessing — much lighter than Exp J
# Exp J scored 2.52 because blur_sigma=2.5 + blend=0.60 destroyed PoseNet cues.
# This config uses much gentler settings: sigma=0.8, blend=0.25
# Only the very top of the frame (sky) gets degraded significantly.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0

# GENTLE ROI preprocessing
ROI_PREPROCESS_ENABLE=1
ROI_PREPROCESS_BLUR_SIGMA=0.8
ROI_PREPROCESS_FEATHER_RADIUS=32
ROI_PREPROCESS_BLEND=0.25
# Wider corridor to protect more of the frame
ROI_PREPROCESS_CORRIDOR_TL=0.10,0.35
ROI_PREPROCESS_CORRIDOR_TR=0.90,0.35
ROI_PREPROCESS_CORRIDOR_BR=1.0,1.0
ROI_PREPROCESS_CORRIDOR_BL=0.0,1.0
ROI_PREPROCESS_ADAPTIVE=0
PRE_DENOISE=
