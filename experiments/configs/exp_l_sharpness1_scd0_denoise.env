# Experiment L: sharpness=1 + scd=0 + hqdn3d (cheapest stacked win attempt)
# sharpness=1 is validated at 2.08. scd=0 is untested. hqdn3d is untested.
# These are the three consensus params from the public leaderboard.
# All top entries use them. They should all help without hurting each other.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:scd=0:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=hqdn3d=1.5:0:0:0
