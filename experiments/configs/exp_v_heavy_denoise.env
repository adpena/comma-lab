# Experiment V: Heavy denoise + film-grain-denoise
# Hypothesis: aggressive edge-preserving denoise + encoder-side grain denoise
# should maximize byte savings while preserving structure for PoseNet.
# The encoder denoises, encodes the clean signal, then re-synthesizes grain at decode.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:film-grain-denoise=1:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0

# Heavy denoise: stronger spatial + temporal
PRE_DENOISE=hqdn3d=3:2:4:3
