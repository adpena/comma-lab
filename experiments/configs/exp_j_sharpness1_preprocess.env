# Experiment J: sharpness=1 + ROI preprocessing
# Combines the validated sharpness=1 floor with preprocessing.
# This is the "public leader approach + our validated winner" combo.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:scd=0:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0

# ROI preprocessing
ROI_PREPROCESS_ENABLE=1
ROI_PREPROCESS_BLUR_SIGMA=2.5
ROI_PREPROCESS_FEATHER_RADIUS=48
ROI_PREPROCESS_BLEND=0.60
ROI_PREPROCESS_CORRIDOR_TL=0.20,0.45
ROI_PREPROCESS_CORRIDOR_TR=0.80,0.45
ROI_PREPROCESS_CORRIDOR_BR=1.0,1.0
ROI_PREPROCESS_CORRIDOR_BL=0.0,1.0
ROI_PREPROCESS_ADAPTIVE=0
PRE_DENOISE=hqdn3d=1.5:0:0:0
