# Experiment A2: VQ mode + QM at higher CRF to compensate for bitrate increase
# Exp A showed that tune=0 + qm + variance-boost at CRF 33 produces 2.18MB (2.5x baseline).
# Fix: raise CRF to 38 to bring bitrate back down. The VQ mode should preserve
# perceptual structure better even at higher CRF.
# Also remove variance-boost which may be the biggest bitrate inflator.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=38
SVT_AV1_PARAMS=tune=0:enable-qm=1:qm-min=0:qm-max=15:film-grain=22:film-grain-denoise=1:keyint=180:scd=0
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0
PRE_DENOISE=hqdn3d=1.5:0:0:0
