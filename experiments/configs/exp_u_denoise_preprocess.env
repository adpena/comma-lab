# Experiment U: Denoise-based preprocessing (NOT blur)
# Key insight: the public leader uses DENOISE not BLUR outside the corridor.
# Denoise preserves edges/structure (which PoseNet needs) while removing noise
# (which wastes encoder bits). Blur destroys structure = kills PoseNet.
#
# This experiment uses hqdn3d as a PRE_DENOISE filter in the downscale chain
# instead of the preprocessing pipeline. This is simpler and avoids the
# frame-by-frame Python processing bottleneck.
#
# hqdn3d applies temporal+spatial denoise that preserves edges.
# Combined with sharpness=1 for edge preservation at the encoder level.

SCALE_W=524
SCALE_H=394
DOWNSCALE_FLAGS=lanczos
UPSCALE_FLAGS=lanczos
VIDEO_CODEC=libsvtav1
SVT_AV1_PRESET=0
SVT_AV1_CRF=34
SVT_AV1_PARAMS=film-grain=22:keyint=180:sharpness=1
SOURCE_W=1164
SOURCE_H=874
SOURCE_COLOR_RANGE=tv
SOURCE_COLOR_MATRIX=bt709
SOURCE_COLOR_PRIMARIES=bt709
SOURCE_COLOR_TRC=bt709
RGB_OUTPUT_RANGE=pc
INFLATE_POSTFILTER=unsharp=9:9:0.35:9:9:0.0
ROI_ENABLE=0
ROI_METADATA_ENABLE=0
ROI_PREPROCESS_ENABLE=0

# Stronger denoise BEFORE downscale (2.5 luma, 2.5 chroma temporal)
# This is what the public leader effectively does
PRE_DENOISE=hqdn3d=2.5:2.5:3:3
