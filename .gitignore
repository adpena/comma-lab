# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environments
.venv/

# macOS / Finder noise
.DS_Store

# Local upstream checkout and machine-specific workspace state
workspace/upstream/
workspace/upstream_snapshot.json
.wrangler/cache/
.tooling/node_modules/

# Live Vast.ai instance tracker — per-machine operational state, NEVER commit.
# Sharing it across checkouts/CI risks foreign automation destroying live
# instances ($0.20-$0.40/hr each). The file STAYS LOCAL with current records;
# this rule simply prevents it from leaking into the shared repo. (Codex F1
# 2026-04-28: tracker had grown to 75 records / ~$305 active spend before
# being caught.)
.omx/state/vastai_active_instances.json
.omx/state/instance_setup_first_seen.json

# Large binary files (GitHub 100MB limit)
*.raw
*.npy
*.safetensors
experiments/cache/
experiments/postfilter_weights/
workspace/tools/

# Model checkpoints and large tensors (use Git LFS or external storage instead)
# Note: some .pt files are intentionally tracked (small backups, reports).
# The ones below are known large files that should never be in git.
experiments/raft_flow.pt
experiments/results/**/*.pt
# Harvest bundles record run_command.sh for traceability — these are
# audit artifacts, not deploy scripts, and should be exempt from the
# "shell-script-in-experiments" preflight rule.
experiments/results/**/run_command.sh
experiments/results/**/*.zip

# Secrets and credentials
.env
*.env.local
*.env.*.local
*_api_key
*.key
credentials.json

# Generated submission scratch artifacts
submissions/robust_current/archive/
submissions/robust_current/inflated/
reports/graphs/site/comparison/*.mp4
reports/graphs/site/comparison/*.gif
reports/graphs/site/comparison/frames/
reports/graphs/site/comma_format/*.mp4
reports/graphs/site/comma_format/*.gif

# Data directories (large, machine-generated)
precomputed_local/
precomputed/
data/runs/*/*.csv
data/runs/*/*.npy
data/runs/*/*.pt
data/runs/*/__pycache__/

# Kaggle kernel bundles — build artifacts, regenerate with:
#   python src/tac/deploy/kaggle/build_kaggle_kernels.py
# Then push with: kaggle kernels push -p experiments/kaggle_kernels/<name>
experiments/kaggle_kernels/

# Python wheel builds
dist/
build/

# Upstream scorer checkout (cloned at runtime, not ours)
upstream/

# Hypothesis test database
.hypothesis/

# Playwright MCP artifacts
.playwright-mcp/

# Kaggle dataset metadata (auto-downloaded)
dataset-metadata.json

# Kaggle kernel logs (downloaded for debugging)
*.log
!.ralph/*.log

# Egg-info (regenerated by setuptools)
src/tac.egg-info/

# Subagent commit serializer artifacts (lock + JSONL log are local-only forensics)
.omx/state/.commit-lock
.omx/state/commit-serializer.log
