# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environments
.venv/

# macOS / Finder noise
.DS_Store

# Local upstream checkout and machine-specific workspace state
workspace/upstream/
workspace/upstream_snapshot.json
.wrangler/cache/
.tooling/node_modules/

# Live Vast.ai instance tracker — per-machine operational state, NEVER commit.
# Sharing it across checkouts/CI risks foreign automation destroying live
# instances ($0.20-$0.40/hr each). The file STAYS LOCAL with current records;
# this rule simply prevents it from leaking into the shared repo. (Codex F1
# 2026-04-28: tracker had grown to 75 records / ~$305 active spend before
# being caught.)
.omx/state/*
!.omx/state/artifact_kind_registry.yaml
.omx/state/vastai_active_instances.json
.omx/state/instance_setup_first_seen.json

# Large binary files (GitHub 100MB limit)
*.raw
*.npy
*.safetensors
experiments/cache/
experiments/postfilter_weights/
workspace/tools/

# Model checkpoints and large tensors (use Git LFS or external storage instead)
# Note: some .pt files are intentionally tracked (small backups, reports).
# The ones below are known large files that should never be in git.
experiments/raft_flow.pt
experiments/results/**/*.pt

# Generated experiment/custody roots are local by default. Preserve signal by
# promoting compact summaries into .omx/research/, docs/, reports/, or source;
# use `git add -f` only for intentionally curated exact-evidence artifacts.
experiments/results/
outputs/

# Local Claude scheduler locks contain machine/session PIDs and must not churn.
.claude/*.lock

# Harvest bundles record run_command.sh for traceability — these are
# audit artifacts, not deploy scripts, and should be exempt from the
# "shell-script-in-experiments" preflight rule.
experiments/results/**/run_command.sh
experiments/results/**/*.zip
experiments/results/lightning_batch/**/source_manifest.json
experiments/results/lightning_batch/**/adjudication_provenance.json
experiments/results/lightning_batch/**/contest_auth_eval*.json
experiments/results/lightning_batch/**/eval_provenance.json
experiments/results/lightning_batch/**/lightning_*.json
experiments/results/lightning_batch/**/lightning_dali_requirements.txt
experiments/results/lightning_batch/**/report.txt

# Secrets and credentials
.env
.env*
!.env.example
*.env.local
*.env.*.local
*_api_key
*.key
credentials.json

# Generated submission scratch artifacts
submissions/*/archive.zip
submissions/*/submission.zip
submissions/*/inflated/
submissions/*/__pycache__/
submissions/robust_current/archive/
submissions/robust_current/inflated/
submission_packets/
reports/public/submission_packets/
reports/graphs/site/comparison/*.mp4
reports/graphs/site/comparison/*.gif
reports/graphs/site/comparison/frames/
reports/graphs/site/comma_format/*.mp4
reports/graphs/site/comma_format/*.gif
reports/graphs/public_site/

# Data directories (large, machine-generated)
precomputed_local/
precomputed/
data/runs/*/*.csv
data/runs/*/*.npy
data/runs/*/*.pt
data/runs/*/__pycache__/

# Kaggle kernel bundles — build artifacts, regenerate with:
#   python src/tac/deploy/kaggle/build_kaggle_kernels.py
# Then push with: kaggle kernels push -p experiments/kaggle_kernels/<name>
experiments/kaggle_kernels/

# Python wheel builds
dist/
build/

# Upstream scorer checkout (cloned at runtime, not ours)
upstream/

# Hypothesis test database
.hypothesis/

# Playwright MCP artifacts
.playwright-mcp/

# Kaggle dataset metadata (auto-downloaded)
dataset-metadata.json

# Kaggle kernel logs (downloaded for debugging)
*.log
!.ralph/*.log

# Egg-info (regenerated by setuptools)
src/tac.egg-info/

# Lab state policy:
# - Track small durable research/control-plane files under .omx/research/ and
#   selected .omx/state/*.md files.
# - Do not track raw provider state, local logs, caches, or rebuildable/hosted
#   artifacts. Canonicalize them into .omx/research ledgers or externalize them
#   with a committed manifest.
# Audit the boundary with:
#   python tools/audit_research_state_tracking.py --repo-root .
#
# Subagent commit serializer artifacts (lock + JSONL log are local-only forensics)
.omx/state/.commit-lock
.omx/state/commit-serializer.log
.omx/state/*.json
.omx/state/**/*.json
.omx/state/*.jsonl
.omx/state/RACE_MODE_ACTIVE.flag
.omx/status/
.omx/research/artifacts/
.omx/logs/
reports/raw/
reports/private/
reports/public/.env

# Ephemeral subagent_commit_serializer.py temp git indexes (per-PID, never commit)
.omx/state/.subagent-temp-index-*
.omx/state/.subagent-temp-index-*.lock
.omx/state/launch_locks/

# Ralph tool backup files (auto-generated)
.ralph/*.bak
# Ephemeral .omx/tmp/ scratch (never commit)
.omx/tmp/

# Wave 11 — exclude vendored upstream test data from public PR intakes
experiments/results/public_pr_intake_full/
experiments/results/public_pr_archive_release_view/
experiments/results/public_pr_archive_kaggle_mirror/
experiments/results/comma_lab_public_export/
experiments/results/public_pr*_intake_*/source/videos/
experiments/results/public_pr*_intake_*/repo/videos/
experiments/results/public_pr*_intake_*/replay_submission/__pycache__/
experiments/results/public_pr*_intake_*/source/.git/
experiments/results/public_pr*_intake_*/source/models/
experiments/results/public_pr*_intake_*/source/ffmpeg-new/
experiments/results/public_pr*_intake_*/repo/.git/
experiments/results/public_pr*_intake_*/repo/models/
experiments/results/public_pr*_intake_*/repo/ffmpeg-new/
experiments/results/public_pr*_intake_*/replay_submission/__pycache__/
experiments/results/public_pr*_intake_*/__pycache__/

# 13MB lightning log (one-time, not durable)
.omx/state/lightning_refresh_all_followup_*.jsonl

# Debug smoke outputs from PHASE 4 canonical orchestrator (rebuildable; not durable)
experiments/results/orch_smoke_*/

# Auto-memory snapshot dirs are interesting, but raw snapshots are operator
# backups. Extract/canonicalize useful material into .omx/research/ or
# docs/paper/ara/ before publishing.
.omx/auto_memory_snapshot_*/
reverse_engineering/orphan_pyc_recovery_20260505_codex/.omx/auto_memory_snapshot_*/

# Per-PR fetched intake dirs: source/ subtrees are large + re-cloneable from each PR's head_repo + sha
# We commit the archive.zip + metadata + provenance JSON, but exclude the cloned source/
experiments/results/public_pr_intake_full/*/source/
